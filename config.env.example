# ----------------------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR DE SEÑALIZACIÓN SGM
# ----------------------------------------------------------------------

# Clave API para autenticar peticiones de los nodos.
# Debe ser una cadena larga y segura. Puedes generarla con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# El resultado será una cadena alfanumérica de 64 caracteres.
API_KEY=copie_aqui

# Clave de encriptación (OPCIONAL) para proteger la URL pública.
# Si la dejas vacía, los endpoints de encriptación devolverán error 404.
# Si deseas usarla, genera una clave válida para Fernet con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# El resultado tendrá el formato "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=" (incluye el signo igual).
ENCRYPTION_KEY=copie_aqui_o_deje_vacio

# Opcional: credenciales para una cuenta premium de Serveo (no necesario en plan gratuito)
SERVEO_USER=
SERVEO_PASS=
