# API Key para autenticar peticiones (cambiar por una segura)
API_KEY=cambia_esta_clave_por_una_segura

# Clave simétrica para encriptar la URL (generar con: python -c "import secrets; print(secrets.token_urlsafe(32))")
ENCRYPTION_KEY=genera_una_clave_unica

# Opcional: usuario/contraseña para cuenta premium de Serveo (no necesario en plan gratuito)
SERVEO_USER=
SERVEO_PASS=
