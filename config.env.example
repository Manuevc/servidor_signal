# ----------------------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR DE SEÑALIZACIÓN SGM
# ----------------------------------------------------------------------

# Clave API para autenticar peticiones de los nodos.
# Debe ser una cadena larga y segura. Puedes generarla con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# El resultado será una cadena alfanumérica de 64 caracteres.
API_KEY=

# Clave de encriptación (OPCIONAL) para proteger la URL pública.
# Si se deja vacía, los endpoints de encriptación devolverán error 404.
# Si desea usarla, genera una clave válida para Fernet con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# El resultado tendrá el formato "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=" (incluye el signo igual).
ENCRYPTION_KEY=

# ----------------------------------------------------------------------
# CONFIGURACIÓN AVANZADA: DOMINIO PERSONALIZADO EN SERVEO (OPCIONAL)
# Solo para usuarios de pago que deseen usar su propio dominio/subdominio.
# Requiere configurar registros DNS (CNAME y TXT) y generar una llave SSH.
# Si se deja estos campos vacíos, el servidor usará la URL aleatoria gratuita
# y no usará el dominio personalizado.
# ----------------------------------------------------------------------

# Dominio o subdominio que deseas usar (ej. "mi-servicio.serveo.net" o "api.midominio.com")
# Debe coincidir con los registros DNS que hayas configurado.
SERVEO_DOMAIN=

# Ruta dentro del contenedor a la llave privada SSH (ej. "/app/keys/id_rsa")
# Esta llave debe ser montada como un volumen o copiada al construir la imagen.
SERVEO_SSH_KEY_PATH=

# Huella (fingerprint) de tu llave pública SSH.
# Se usa para configurar el registro TXT en DNS: _serveo-authkey.[dominio] = [huella]
# No es estrictamente necesaria para el script, pero es un recordatorio para tu configuración DNS.
# Puedes obtenerla con: ssh-keygen -l -f ~/.ssh/id_rsa.pub
SERVEO_SSH_KEY_FINGERPRINT=
